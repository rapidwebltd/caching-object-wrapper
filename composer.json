{
    "name": "rapidwebltd/caching-object-wrapper",
    "description": "Wraps up any PHP object so all its methods are cached.",
    "type": "library",
    "authors": [
        {
            "name": "Jordan Hall",
            "email": "jordan.hall@rapidweb.biz"
        }
    ],
    "license": "LGPL-3.0-only",
    "require": {
        "php": ">=5.6",
        "psr/cache": "^1.0 || ^2.0 || ^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^5.7 || ^9.6",
        "rapidwebltd/rw-file-cache-psr-6": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "RapidWeb\\CachingObjectWrapper\\": "src/"
        }
    }
}
